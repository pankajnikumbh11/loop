generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  feedback  Feedback[]
  themes    Theme[]
  reports   Report[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())

  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  reports      Report[]
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

model Feedback {
  id             String     @id @default(cuid())
  content        String
  channel        String
  sourceRef      String?
  customerLabel  String?
  sentiment      Sentiment?
  sentimentScore Float?
  status         Status     @default(NEW)
  createdAt      DateTime   @default(now())

  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])

  themes         FeedbackTheme[]
  embedding      Embedding?
}

enum Sentiment {
  POS
  NEU
  NEG
}

enum Status {
  NEW
  REVIEWED
  ACTIONED
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  feedback    FeedbackTheme[]
}

model FeedbackTheme {
  feedbackId String
  themeId    String
  confidence Float?

  feedback   Feedback @relation(fields: [feedbackId], references: [id])
  theme      Theme    @relation(fields: [themeId], references: [id])

  @@id([feedbackId, themeId])
}

model Embedding {
  id         String   @id @default(cuid())
  feedbackId String   @unique
  vector     Float[]

  feedback   Feedback @relation(fields: [feedbackId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  title       String
  periodStart DateTime
  periodEnd   DateTime
  contentJson Json
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  generatedById String
  generatedBy   User @relation(fields: [generatedById], references: [id])
}